{
  "plugin_id": "continuum.local-audiobooks",
  "version": "1.0.0",
  "checksum": "e98f52a29a3a752c1565432f321c746aed29cdfcd8c65ebfc3efa0a3af3ebc9f",
  "continuum_api_version": "v1",
  "category": "Books/Audiobooks",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "audiobook_backend.v1",
      "id": "local_audiobooks",
      "display_name": "Local Audiobooks Library",
      "description": "Scans local audiobook libraries and exposes them to the Audiobooks portal.",
      "metadata": {
        "audiobook_roles": [
          "library_source"
        ],
        "supports_catalog": true,
        "supports_requests": false,
        "supports_auto_monitoring": false
      }
    },
    {
      "type": "http_routes.v1",
      "id": "api",
      "display_name": "Catalog + admin HTTP routes"
    },
    {
      "type": "scheduled_task.v1",
      "id": "library_scan",
      "display_name": "Periodic library rescan",
      "cron": "0 */6 * * *"
    },
    {
      "type": "metadata_provider.v1",
      "id": "local_audiobooks_meta",
      "display_name": "Local Audiobooks metadata aggregator",
      "description": "Searches Audnexus, AudiMeta, iTunes, Storytel, BookBeat, Audioteka, and Audiobookcovers.",
      "metadata": {
        "default_priority": {
          "audiobook": 1
        }
      }
    },
    {
      "type": "scheduled_task.v1",
      "id": "metadata_enrichment_worker",
      "display_name": "Metadata enrichment worker",
      "cron": "* * * * *"
    }
  ],
  "http_routes": [
    {
      "id": "stream",
      "method": "GET",
      "path": "/api/v1/stream/*",
      "access": "public"
    },
    {
      "id": "cover",
      "method": "GET",
      "path": "/api/v1/cover/*",
      "access": "public"
    },
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/*",
      "access": "authenticated"
    },
    {
      "id": "admin_root",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Local Audiobooks",
      "navigation_kind": "admin"
    },
    {
      "id": "admin",
      "method": "*",
      "path": "/admin/*",
      "access": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated local_audiobooks schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    }
  ]
}
